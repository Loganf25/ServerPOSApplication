@page
@model ServerPOSApplication.Pages.CRUD_Pages.Orders.IndexModel

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-page="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.Order[0].Employee)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Order[0].SubTotal)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Order[0].AfterTaxTotal)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Order[0].AfterDiscountTotal)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Order[0].FinalTotal)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Order[0].OrderDate)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model.Order) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.Employee.Id)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.SubTotal)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.AfterTaxTotal)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.AfterDiscountTotal)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.FinalTotal)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.OrderDate)
            </td>
            <td>
                <a asp-page="./Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-page="./Details" asp-route-id="@item.Id">Details</a> |
                <a asp-page="./Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
