    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Order.Employee)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Order.Employee.Id)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Order.SubTotal)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Order.SubTotal)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Order.DiscountAmount)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Order.DiscountAmount)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Order.PreTaxTotal)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Order.PreTaxTotal)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Order.TaxAmount)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Order.TaxAmount)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Order.FinalTotal)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Order.FinalTotal)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Order.OrderDate)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Order.OrderDate)
        </dd>
    </dl>
</div>
<div>
    <a asp-page="./Edit" asp-route-id="@Model.Order.Id">Edit</a> |
    <a asp-page="./Index">Back to List</a>
</div>
