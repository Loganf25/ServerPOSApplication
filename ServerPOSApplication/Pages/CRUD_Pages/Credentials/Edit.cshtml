@page "{id:int}"
@model ServerPOSApplication.Pages.CRUD_Pages.Credentials.EditModel

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>Credential</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Credential.Id" />
            <div class="form-group">
                <label asp-for="Credential.EmployeeId" class="control-label"></label>
                <select asp-for="Credential.EmployeeId" class="form-control" asp-items="ViewBag.EmployeeId" ></select>
                <span asp-validation-for="Credential.EmployeeId" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Credential.UserName" class="control-label"></label>
                <input asp-for="Credential.UserName" class="form-control" />
                <span asp-validation-for="Credential.UserName" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Credential.PasswordHash" class="control-label"></label>
                <input asp-for="Credential.PasswordHash" class="form-control" />
                <span asp-validation-for="Credential.PasswordHash" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-page="./Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
