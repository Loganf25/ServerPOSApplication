@using Microsoft.AspNetCore.Identity
@using ServerPOSApplication.Models
@using ServerPOSApplication.Data
@inject SignInManager<IdentityUser> SignInManager
@inject ServerPOSApplicationContext DbContext

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Server Order System</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ServerPOSApplication.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container">
                <a class="navbar-brand" asp-area="" asp-page="/Index">ServerPOSApplication</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        @if (SignInManager.IsSignedIn(User))
                            {
                                var userId = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
                                var isProfileComplete = DbContext.Employees.Any(e => e.IdentityUserId == userId);

                                @if (isProfileComplete)
                                {
                                    @if (User.IsInRole("Manager"))
                                    {
                                        <li class="nav-item"><a class="nav-link" asp-page="/CRUD_Pages/Employees/Index">Manage Employees</a></li>
                                        <li class="nav-item"><a class="nav-link" asp-page="/CRUD_Pages/MenuItems/Index">Manage Menu</a></li>
                                        <li class="nav-item"><a class="nav-link" asp-page="/CRUD_Pages/Taxes/Index">Manage Taxes</a></li>
                                        <li class="nav-item"><a class="nav-link" asp-page="/CRUD_Pages/Discounts/Index">Manage Discounts</a></li>
                                    }
                                    <li class="nav-item"><a class="nav-link text-dark" asp-area="" asp-page="/Index">Place Order</a></li>
                                    <li class="nav-item"><a class="nav-link" asp-page="/CRUD_Pages/Orders/Index">Orders</a></li>
                                    <form id="logoutForm" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="~/" method="post" class="d-inline">
                                        <button type="submit" class="nav btn btn-link">Logout</button>
                                    </form>
                                }
                                else
                                {
                                    <li class="nav-item"><a class="nav-link text-danger font-weight-bold" asp-page="/CRUD_Pages/Employees/FinishProfile">Complete Profile Setup First</a></li>
                                }
                            }
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Privacy">Privacy</a>
                        </li>
                        </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - ServerPOSApplication - <a asp-area="" asp-page="/Privacy">Privacy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
